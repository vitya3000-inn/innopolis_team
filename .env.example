NEWS_API_KEY=replace_with_your_newsapi_key
PORT=8787
TARGET_LANGUAGE=ru
NEWS_LOOKBACK_DAYS=3
NEWS_REQUEST_DELAY_MS=1000
NEWS_CACHE_TTL_MS=21600000
MAX_ARTICLES_PER_SOURCE=50
MAX_EVENTS_PER_TOPIC=15
# OpenAI (опционально): если пусто — бэкенд работает без LLM, как раньше.
# Экономия: gpt-4o-mini, батчи, кэш в backend/data/llm-cache.json
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BATCH_SIZE=5
OPENAI_MAX_EVENTS_PER_REFRESH=25
OPENAI_MAX_TOKENS_PER_BATCH=1200
OPENAI_MAX_SNIPPETS_PER_EVENT=4
OPENAI_TOPIC_COUNT=5
OPENAI_MIN_TOPIC_RELEVANCE=0.45
# Для запуска на телефоне через Expo Go укажи IP ноутбука в локальной сети:
# EXPO_PUBLIC_API_URL=http://192.168.1.100:8787
EXPO_PUBLIC_API_URL=http://localhost:8787
